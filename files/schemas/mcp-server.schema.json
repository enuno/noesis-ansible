{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Server",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "transport": {
      "type": "string"
    },
    "tools": {
      "type": "array"
    },
    "tool_groups": {
      "type": "array"
    },
    "approved": {
      "type": "boolean"
    },
    "allowed_agents": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "name",
    "version",
    "approved"
  ]
}