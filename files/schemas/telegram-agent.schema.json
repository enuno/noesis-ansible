{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Telegram Agent",
  "type": "object",
  "properties": {
    "agent_name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "telegram_bot"
      ]
    },
    "group": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "transport": {
      "type": "string"
    },
    "registered_at": {
      "type": "string"
    }
  },
  "required": [
    "agent_name",
    "type",
    "group"
  ]
}