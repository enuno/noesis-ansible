{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACP Registry Agent",
  "type": "object",
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "deprecated"
      ]
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "endpoint": {
      "type": "string",
      "format": "uri"
    },
    "version": {
      "type": "string"
    },
    "registered_at": {
      "type": "string"
    }
  },
  "required": [
    "agent_id",
    "name",
    "status"
  ]
}