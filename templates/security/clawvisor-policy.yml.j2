policies:
  - name: default-deny
    action: deny
    resources:
      - '*'
  - name: allow-local-registries
    action: allow
    resources:
      - 'localhost:8081'
      - 'localhost:8082'
      - 'localhost:8083'
      - 'localhost:8084'
      - 'localhost:8085'
  - name: allow-approved-mcps
    action: allow
    resources:
      - '{{ mcpjungle_url | default("http://localhost:8085") }}'
