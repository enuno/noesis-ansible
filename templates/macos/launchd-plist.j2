<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.noesis.{{ service_name }}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ service_binary }}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{ log_dir | default(ansible_env.HOME + '/.local/share/noesis') }}/{{ service_name }}.log</string>
  <key>StandardErrorPath</key>
  <string>{{ log_dir | default(ansible_env.HOME + '/.local/share/noesis') }}/{{ service_name }}.err</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
