# MemPalace Configuration for {{ item.name }}
# Generated by Ansible — do not edit manually

agent:
  name: {{ item.name }}
  port: {{ item.port }}

memory:
  primary: true
  isolated: true
  data_dir: /data

mcp:
  enabled: {{ mempalace_mcp_enabled | lower }}
  endpoint: "http://localhost:{{ item.port }}/mcp"

hooks:
  enabled: {{ mempalace_hooks_enabled | lower }}
  events:
    - capture
    - mine
    - wakeup
    - retrieve

logging:
  level: {{ mempalace_log_level }}
