# MemPalace Hooks Configuration
# Generated by Ansible — do not edit manually

hooks:
{% for agent in mempalace_agents %}
  - agent: {{ agent.name }}
    trigger: capture
    action: store
    target: local

  - agent: {{ agent.name }}
    trigger: mine
    action: extract
    target: local

  - agent: {{ agent.name }}
    trigger: wakeup
    action: hydrate
    target: local

  - agent: {{ agent.name }}
    trigger: retrieve
    action: search
    target: local
{% endfor %}
