# SkillNet Agent Bindings
# Generated by Ansible — do not edit manually

bindings:
  - agent: openclaw
    endpoint: {{ skillnet_openclaw_binding }}
    capabilities:
      - skill_search
      - skill_install

  - agent: hermes
    endpoint: {{ skillnet_hermes_binding }}
    capabilities:
      - skill_search
      - skill_evaluate
      - skill_install
