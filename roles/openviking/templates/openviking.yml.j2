---
# OpenViking configuration — generated by Ansible
# Role: openviking

server:
  port: {{ openviking_port }}
  workers: {{ openviking_worker_count }}

logging:
  level: {{ openviking_log_level }}

cluster:
  mode: {{ openviking_cluster_mode }}
{% if openviking_cluster_join | length > 0 %}
  join:
{% for node in openviking_cluster_join.split(',') %}
    - {{ node | trim }}
{% endfor %}
{% endif %}
