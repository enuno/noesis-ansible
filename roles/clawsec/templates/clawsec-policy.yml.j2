# ClawSec Security Policy
# Generated by Ansible — do not edit manually

severity_threshold: {{ clawsec_policy_severity }}

categories:
{% for category in clawsec_policy_categories %}
  - {{ category }}
{% endfor %}

rules:
  - id: prompt-injection-detection
    category: prompt_injection
    severity: critical
    pattern: "ignore previous instructions|disregard.*prompt|override.*system"

  - id: data-exfiltration-detection
    category: data_exfiltration
    severity: high
    pattern: "send.*data.*to|exfiltrate|upload.*external"

  - id: privilege-escalation-detection
    category: privilege_escalation
    severity: high
    pattern: "sudo|root|admin.*bypass|elevate.*privilege"

  - id: unsafe-code-execution
    category: unsafe_code_execution
    severity: critical
    pattern: "eval\\(|exec\\(|system\\(|subprocess\\.call"

scan_options:
  recursive: true
  include_hidden: false
  max_file_size_mb: 10
