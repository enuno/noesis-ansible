<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.noesis.clawdev</string>
  <key>ProgramArguments</key>
  <array>
    <string>{{ clawdev_home }}/.local/bin/openclaw</string>
    <string>--config</string>
    <string>{{ clawdev_home }}/.config/noesis/clawdev/config.json</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>{{ clawdev_home }}/.local/share/noesis/clawdev.log</string>
  <key>StandardErrorPath</key>
  <string>{{ clawdev_home }}/.local/share/noesis/clawdev.err</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
