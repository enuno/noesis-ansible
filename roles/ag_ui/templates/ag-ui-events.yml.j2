# AG-UI Event Routing Rules
# Generated by Ansible — do not edit manually

events:
  - name: agent_message
    route: backends.hermes
    require_approval: false

  - name: user_action
    route: backends.openclaw
    require_approval: {{ ag_ui_hitl_enabled | lower }}

  - name: tool_call
    route: backends.hermes
    require_approval: true

  - name: session_start
    route: backends.hermes
    require_approval: false

  - name: session_end
    route: backends.hermes
    require_approval: false
