# AG-UI Configuration
# Generated by Ansible — do not edit manually

server:
  port: {{ ag_ui_port }}
  base_url: {{ ag_ui_base_url }}

endpoints:
  events: {{ ag_ui_event_endpoint }}
  actions: {{ ag_ui_action_endpoint }}
  health: {{ ag_ui_health_endpoint }}

human_in_the_loop:
  enabled: {{ ag_ui_hitl_enabled | lower }}
  timeout_seconds: {{ ag_ui_hitl_timeout_seconds }}

backends:
  openclaw: {{ ag_ui_openclaw_backend }}
  hermes: {{ ag_ui_hermes_backend }}

logging:
  level: {{ ag_ui_log_level }}
