# OpenClaw Gateway Configuration
# Generated by Ansible — do not edit manually

gateway:
  host: {{ openclaw_gateway_host }}
  port: {{ openclaw_gateway_port }}
  url: {{ openclaw_gateway_url }}
  health_path: {{ openclaw_gateway_health_path }}

acp:
  enabled: {{ openclaw_acp_bridge_enabled | lower }}
  mode: {{ openclaw_acp_bridge_mode }}
  command: {{ openclaw_acp_bridge_command }}
  socket: {{ openclaw_acp_bridge_socket }}

auth:
  token: "{{ openclaw_acp_auth_token }}"
