[Unit]
Description=OpenClaw ACP Gateway
After=network.target

[Service]
Type=simple
ExecStart={{ openclaw_install_dir }}/openclaw acp --gateway {{ openclaw_gateway_url }} --config {{ openclaw_config_dir }}/acp-bridge.yml
Restart=on-failure
RestartSec=5
User=openclaw
Group=openclaw

[Install]
WantedBy=multi-user.target
