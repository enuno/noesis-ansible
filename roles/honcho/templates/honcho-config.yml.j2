# Honcho Configuration
# Generated by Ansible — do not edit manually

server:
  port: {{ honcho_port }}
  base_url: {{ honcho_base_url }}

capabilities:
  reasoning: {{ honcho_reasoning_enabled | lower }}
  peer_cards: {{ honcho_peer_cards_enabled | lower }}
  dreaming: {{ honcho_dreaming_enabled | lower }}
  streaming: {{ honcho_streaming_enabled | lower }}
  file_uploads: {{ honcho_file_uploads_enabled | lower }}

security:
  auth_enabled: {{ honcho_auth_enabled | lower }}
  api_key: "{{ honcho_api_key }}"

database:
  url: "postgresql://honcho:{{ honcho_db_password }}@localhost:5432/honcho"

logging:
  level: {{ honcho_log_level }}
