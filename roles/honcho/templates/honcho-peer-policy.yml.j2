# Honcho Peer Card Policy
# Generated by Ansible — do not edit manually

peer_cards:
  enabled: {{ honcho_peer_cards_enabled | lower }}

rules:
  - name: stable_facts_only
    description: Only stable, non-sensitive facts may be promoted
    allowed_fields:
      - name
      - role
      - preferences
      - standing_instructions
      - identity_anchors
    forbidden_fields:
      - secrets
      - credentials
      - private_keys
      - ephemeral_tokens
      - raw_reasoning

  - name: atomic_entries
    description: Peer card entries must be atomic and deduplicated
    max_entry_length: 2048

  - name: validation_gate
    description: All promotions require explicit validation
    require_approval: true
