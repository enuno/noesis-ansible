# Hermes ACP Adapter Configuration
# Generated by Ansible — do not edit manually
# https://hermes-agent.nousresearch.com/docs/developer-guide/acp-internals

acp:
  enabled: true
  mode: {{ hermes_acp_mode }}
  transport: {{ hermes_acp_transport }}
  session_prefix: {{ hermes_acp_session_prefix }}

agent:
  name: {{ hermes_agent_name }}
  role: {{ hermes_agent_role }}
  capabilities: {{ hermes_agent_capabilities | to_json }}
  protocols: {{ hermes_agent_protocols | to_json }}
  owner: {{ hermes_agent_owner }}
  supervisor: {{ hermes_supervisor_name }}

supervisor:
  name: {{ hermes_supervisor_name }}
  endpoint: {{ hermes_supervisor_endpoint }}

security:
  approval_required: true
  expose_internal_state: false

logging:
  level: info
